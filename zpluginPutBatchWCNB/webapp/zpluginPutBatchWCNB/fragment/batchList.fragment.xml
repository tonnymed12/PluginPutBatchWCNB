<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
  xmlns:l="sap.ui.layout">

     	<TableSelectDialog
          id="batchListDialog"
          title="{i18n>fragmentTitle}"
          items="{/ITEMS}"
          cancel="onCloseDialogBatchChars"
          confirm="onSelectBatch"
     >
              <columns>
                <Column>
                  <Label text="{i18n>material}"/>
                </Column>
                <Column>
                  <Label text="{i18n>lote}"/>
                </Column>
                <Column>
                  <Label text="{i18n>cantidad}"/>
                </Column>
                 <Column>
                  <Label text="{i18n>cantidadRequerida}"/>
                </Column>
                <Column>
                  <Label text="{i18n>codigo}"/>
                </Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{MATERIAL}" width="250px"/> 
                    <Text text="{LOTE}" width="auto"/> 
                    <Text text="{CANTIDAD}" width="auto"/> 
                    <Text text="{CANTIDADREQUERIDA}" width="auto"/>   
                    <Input type="Text" value="{CODIGO}" width="300px" enabled="false"/>
                  </cells>
                </ColumnListItem>
              </items>

</TableSelectDialog>
</c:FragmentDefinition>