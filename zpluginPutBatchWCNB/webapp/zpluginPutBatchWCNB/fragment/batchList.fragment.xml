<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
  xmlns:l="sap.ui.layout">

  <Dialog
     id="batchListDialog"
     title="{i18n>fragmentTitle}">
    <l:VerticalLayout
      class="sapUiContentPadding"
      width="100%">
      <l:content>
        <Panel
            width="100%"
            class="sapUiResponsiveMargin sapUiNoContentPadding">
          <content>
            <Table
                   id="list"
                   class="sapUiResponsiveMargin"
                   width="100%"
                   items="{/ITEMS}">
              <columns>
                <Column>
                  <Label text="{i18n>material}"/>
                </Column>
                <Column>
                  <Label text="{i18n>lote}"/>
                </Column>
                <Column>
                  <Label text="{i18n>cantidad}"/>
                </Column>
                 <Column>
                  <Label text="{i18n>cantidadRequerida}"/>
                </Column>
                <Column>
                  <Label text="{i18n>codigo}"/>
                </Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{MATERIAL}"/> 
                    <Text text="{LOTE}"/> 
                    <Text text="{CANTIDAD}" /> 
                    <Text text="{CANTIDADREQUERIDA}"/>   
                    <Input type="Text" value="{CODIGO}"/>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </content>
        </Panel>
      </l:content>
    </l:VerticalLayout>

    <beginButton>
      <Button
       type="Accept"
         text="{i18n>accept}"
         icon="sap-icon://add-product"
         press="onConfirmSendBatchChars"/>
    </beginButton>
    <endButton>
      <Button
         type="Reject"
         text="{i18n>cancel}"
         icon="sap-icon://cancel"
         press="onCloseDialogBatchChars"/>
    </endButton>

  </Dialog>
</c:FragmentDefinition>